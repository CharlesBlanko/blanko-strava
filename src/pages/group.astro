---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { getCommunalActivities } from '../lib/database';
import { calculateGroupStats, formatDistance, formatTime, formatElevation } from '../lib/utils';
import { SessionManager } from '../lib/session';

function getSessionId(request: Request): string | null {
  const cookies = request.headers.get('cookie');
  if (!cookies) return null;
  
  const sessionIdMatch = cookies.match(/sessionId=([^;]+)/);
  return sessionIdMatch ? sessionIdMatch[1] : null;
}

const sessionId = getSessionId(Astro.request);
const session = sessionId ? SessionManager.getSession(sessionId) : null;

if (!session || SessionManager.isTokenExpired(sessionId) || !session.isClubMember) {
  return Astro.redirect('/');
}

const url = new URL(Astro.request.url);
const period = url.searchParams.get('period') || 'allTime';

const clubId = import.meta.env.STRAVA_CLUB_ID || '1452985';

let groupStats = null;
let error = null;

try {
  console.log('=== Starting group page data fetch ===');
  
  // Récupérer toutes les activités de la base commune
  const activities = getCommunalActivities();
  console.log('Communal activities found:', activities.length);
  
  if (activities.length > 0) {
    groupStats = calculateGroupStats(activities);
    console.log('Group stats calculated successfully');
  } else {
    console.log('No activities found in communal database');
    error = 'Aucune activité trouvée dans la base de données. Veuillez synchroniser vos activités.';
  }
} catch (err) {
  error = err.message;
  console.error('Error fetching group stats:', err);
}
---

<Layout title="Statistiques du groupe - Strava Club Tracker">
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <Header />

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-8">
        <div class="flex justify-between items-center mb-6">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Statistiques cumulatives du groupe</h1>
          
          <div class="flex items-center space-x-4">
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Période:</label>
            <select 
              id="period-select"
              class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-orange-500 bg-white text-gray-900 dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100"
              onchange="window.location.href = `/group?period=${this.value}`"
            >
              <option value="lastWeek" selected={period === 'lastWeek'}>La semaine passée</option>
              <option value="weekly" selected={period === 'weekly'}>Cette semaine</option>
              <option value="monthly" selected={period === 'monthly'}>Ce mois</option>
              <option value="yearly" selected={period === 'yearly'}>Cette année</option>
              <option value="allTime" selected={period === 'allTime'}>Depuis toujours</option>
            </select>
          </div>
        </div>

        {error ? (
          <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-6 dark:bg-red-900 dark:border-red-700">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800 dark:text-red-200">Erreur</h3>
                <div class="mt-2 text-sm text-red-700 dark:text-red-300">
                  <p>{error}</p>
                </div>
              </div>
            </div>
          </div>
        ) : groupStats ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow-sm p-6 dark:bg-gray-800">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <svg class="w-8 h-8 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                  </svg>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Distance totale</p>
                  <p class="text-2xl font-bold text-gray-900 dark:text-white">
                    {formatDistance(groupStats[period].distance)}
                  </p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow-sm p-6 dark:bg-gray-800">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <svg class="w-8 h-8 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Temps d'activité</p>
                  <p class="text-2xl font-bold text-gray-900 dark:text-white">
                    {formatTime(groupStats[period].movingTime)}
                  </p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow-sm p-6 dark:bg-gray-800">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <svg class="w-8 h-8 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                  </svg>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Dénivelé positif</p>
                  <p class="text-2xl font-bold text-gray-900 dark:text-white">
                    {formatElevation(groupStats[period].elevationGain)}
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow-sm p-6 dark:bg-gray-800">
            <h2 class="text-lg font-medium text-gray-900 mb-4 dark:text-white">Détails par période</h2>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-700">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-300">
                      Période
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-300">
                      Distance
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-300">
                      Temps d'activité
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-300">
                      Dénivelé positif
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-300">
                      Membres actifs
                    </th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200 dark:bg-gray-800 dark:divide-gray-700">
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                      Cette semaine
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatDistance(groupStats.weekly.distance)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatTime(groupStats.weekly.movingTime)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatElevation(groupStats.weekly.elevationGain)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {groupStats.weekly.memberCount}
                    </td>
                  </tr>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                      La semaine passée
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatDistance(groupStats.lastWeek.distance)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatTime(groupStats.lastWeek.movingTime)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatElevation(groupStats.lastWeek.elevationGain)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {groupStats.lastWeek.memberCount}
                    </td>
                  </tr>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                      Ce mois
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatDistance(groupStats.monthly.distance)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatTime(groupStats.monthly.movingTime)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatElevation(groupStats.monthly.elevationGain)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {groupStats.monthly.memberCount}
                    </td>
                  </tr>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                      Cette année
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatDistance(groupStats.yearly.distance)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatTime(groupStats.yearly.movingTime)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {formatElevation(groupStats.yearly.elevationGain)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                      {groupStats.yearly.memberCount}
                    </td>
                  </tr>
                  <tr class="hover:bg-gray-50 bg-orange-50 dark:hover:bg-gray-700 dark:bg-orange-900">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-orange-900 dark:text-orange-200">
                      Depuis toujours
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-orange-900 dark:text-orange-200">
                      {formatDistance(groupStats.allTime.distance)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-orange-900 dark:text-orange-200">
                      {formatTime(groupStats.allTime.movingTime)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-orange-900 dark:text-orange-200">
                      {formatElevation(groupStats.allTime.elevationGain)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-orange-900 dark:text-orange-200">
                      {groupStats.allTime.memberCount}
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        ) : (
          <div class="text-center py-12">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gray-100 rounded-full mb-4 dark:bg-gray-700">
              <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-2 dark:text-white">Chargement des statistiques...</h3>
            <p class="text-gray-500 dark:text-gray-400">Veuillez patienter pendant que nous récupérons les données du club.</p>
          </div>
        )}
      </div>
    </main>
  </div>
</Layout>
