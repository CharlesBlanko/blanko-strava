---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { getCommunalActivities, getDatabaseInfo, exportDatabase, clearDatabase, getAthleteById } from '../lib/database';
import { SessionManager } from '../lib/session';

function getSessionId(request: Request): string | null {
  const cookies = request.headers.get('cookie');
  if (!cookies) return null;
  
  const sessionIdMatch = cookies.match(/sessionId=([^;]+)/);
  return sessionIdMatch ? sessionIdMatch[1] : null;
}

const sessionId = getSessionId(Astro.request);
const session = sessionId ? SessionManager.getSession(sessionId) : null;

if (!session || SessionManager.isTokenExpired(sessionId) || !session.isClubMember) {
  return Astro.redirect('/');
}

const clubId = import.meta.env.STRAVA_CLUB_ID || '1452985';
const activities = getCommunalActivities();
const dbInfo = getDatabaseInfo();
---

<Layout title="Debug Base de Données - Strava Club Tracker">
  <div class="min-h-screen bg-gray-50">
    <Header />

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="bg-white shadow-sm rounded-lg overflow-hidden">
        <div class="px-6 py-8">
          <h1 class="text-2xl font-bold text-gray-900 mb-6">Base de Données Persistante</h1>
          
          <div class="mb-6">
            <div class="bg-green-50 border border-green-200 rounded-md p-4">
              <h3 class="text-sm font-medium text-green-800 mb-2">📁 Informations Fichier</h3>
              <div class="text-sm text-green-700">
                <p><strong>Club ID:</strong> {clubId}</p>
                <p><strong>Fichier:</strong> src/data/activities.json</p>
                <p><strong>Nombre d'activités:</strong> {dbInfo.activitiesCount}</p>
                <p><strong>Dernière mise à jour:</strong> {new Date(dbInfo.lastUpdated).toLocaleString('fr-FR')}</p>
                <p><strong>Taille du fichier:</strong> {dbInfo.fileSize}</p>
              </div>
            </div>
          </div>

          <div class="mb-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Actions</h3>
            <div class="flex flex-wrap gap-4">
              <form action="/debug/export" method="post">
                <button 
                  type="submit"
                  class="px-4 py-2 text-sm font-medium text-blue-600 bg-blue-100 border border-blue-300 rounded-md hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                >
                  📥 Exporter JSON
                </button>
              </form>
              
              <form action="/debug/clear" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer toutes les activités ?');">
                <button 
                  type="submit"
                  class="px-4 py-2 text-sm font-medium text-red-600 bg-red-100 border border-red-300 rounded-md hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
                >
                  🗑️ Vider la base
                </button>
              </form>
            </div>
          </div>

          <div class="mb-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Activités Détail</h3>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Athlète</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nom</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Distance</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  {activities.slice(0, 50).map((activity) => (
                    <tr key={activity.id} class="hover:bg-gray-50">
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        {activity.id}
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        {(() => {
                          const athlete = getAthleteById(activity.athlete_id);
                          return athlete ? `${athlete.firstname} ${athlete.lastname}` : 'Unknown';
                        })()}
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        {activity.name || 'Sans nom'}
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        {activity.distance ? `${(activity.distance / 1000).toFixed(2)} km` : 'N/A'}
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        {activity.start_date ? new Date(activity.start_date).toLocaleDateString('fr-FR') : 'N/A'}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
              {activities.length > 50 && (
                <div class="mt-4 text-sm text-gray-600 text-center">
                  Affichage des 50 premières activités sur {activities.length} au total
                </div>
              )}
            </div>
          </div>

          <div class="mt-8">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Aperçu JSON</h3>
            <div class="bg-gray-50 rounded-md p-4">
              <pre class="text-xs text-gray-700 overflow-x-auto">
                {JSON.stringify(activities.slice(0, 3), null, 2)}
              </pre>
              {activities.length > 3 && (
                <div class="mt-2 text-sm text-gray-600">
                  Affichage des 3 premières activités sur {activities.length} au total
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>
