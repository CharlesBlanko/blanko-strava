---
import Layout from '../layouts/Layout.astro';
import { StravaAPI } from '../lib/strava';
import { SessionManager, getCachedData, setCachedData } from '../lib/session';
import { getCommunalActivities } from '../lib/database';
import { calculateStats, formatDistance, formatTime, formatElevation } from '../lib/utils';

function getSessionId(request: Request): string | null {
  const cookies = request.headers.get('cookie');
  if (!cookies) return null;
  
  const sessionIdMatch = cookies.match(/sessionId=([^;]+)/);
  return sessionIdMatch ? sessionIdMatch[1] : null;
}

const sessionId = getSessionId(Astro.request);
const session = sessionId ? SessionManager.getSession(sessionId) : null;

if (!session || SessionManager.isTokenExpired(sessionId) || !session.isClubMember) {
    return Astro.redirect('/');
}

const url = new URL(Astro.request.url);
const period = url.searchParams.get('period') || 'allTime';
const sortBy = url.searchParams.get('sortBy') || 'name';
const sortOrder = url.searchParams.get('sortOrder') || 'asc';

// Fonctions utilitaires pour les URLs de tri
function getSortUrl(column: string): string {
  const newSortOrder = sortBy === column && sortOrder === 'asc' ? 'desc' : 'asc';
  return `/members?period=${period}&sortBy=${column}&sortOrder=${newSortOrder}`;
}

function getSortIcon(column: string): string {
  if (sortBy !== column) return '';
  return sortOrder === 'asc' ? '↑' : '↓';
}

const strava = new StravaAPI();
const clubId = import.meta.env.STRAVA_CLUB_ID || '1452985';

let membersStats = [];
let error = null;

// Fonction principale async
async function fetchMembersData() {
  try {
    console.log('=== Starting members page data fetch ===');
    
    // Récupérer toutes les activités de la base commune
    const clubId = import.meta.env.STRAVA_CLUB_ID || '1452985';
    const allCommunalActivities = getCommunalActivities(clubId);
    console.log('Communal activities found:', allCommunalActivities.length);
    
    if (allCommunalActivities.length === 0) {
      console.log('No activities in communal database');
      return [];
    }
    
    // Extraire tous les athlètes uniques des activités
    const uniqueAthletes = new Map();
    allCommunalActivities.forEach(activity => {
      if (activity.athlete) {
        const athleteKey = `${activity.athlete.firstname} ${activity.athlete.lastname}`;
        if (!uniqueAthletes.has(athleteKey)) {
          uniqueAthletes.set(athleteKey, {
            id: activity.athlete.id,
            firstname: activity.athlete.firstname,
            lastname: activity.athlete.lastname,
            username: activity.athlete.username || `${activity.athlete.firstname.toLowerCase()}_${activity.athlete.lastname.toLowerCase()}`,
            profile: activity.athlete.profile_medium || `https://ui-avatars.com/api/?name=${encodeURIComponent(activity.athlete.firstname + '+' + activity.athlete.lastname)}&background=fc4c02&color=fff&size=128`
          });
        }
      }
    });
    
    console.log('Unique athletes found:', uniqueAthletes.size);
    
    // Filtrer pour Charles, Philippe et Jonathan
    const targetAthletes = Array.from(uniqueAthletes.values()).filter(athlete => 
      (athlete.firstname === 'Charles' && athlete.lastname === 'R.') ||
      (athlete.firstname === 'Philippe' && athlete.lastname === 'D.') ||
      (athlete.firstname === 'Jonathan' && athlete.lastname === 'B.')
    );
    
    console.log('Target athletes:', targetAthletes.map(a => `${a.firstname} ${a.lastname}`));
    
    // Calculer les stats pour chaque athlète
    membersStats = targetAthletes.map(athlete => {
      const athleteName = `${athlete.firstname} ${athlete.lastname}`;
      const stats = calculateStats(allCommunalActivities, athleteName);
      
      return {
        ...athlete,
        stats
      };
    });
    
    // Tri des membres
    membersStats.sort((a, b) => {
      let aValue, bValue;
      
      switch (sortBy) {
        case 'name':
          aValue = `${a.firstname} ${a.lastname}`.toLowerCase();
          bValue = `${b.firstname} ${b.lastname}`.toLowerCase();
          break;
        case 'distance':
          aValue = a.stats[period].distance;
          bValue = b.stats[period].distance;
          break;
        case 'time':
          aValue = a.stats[period].movingTime;
          bValue = b.stats[period].movingTime;
          break;
        case 'calories':
          aValue = a.stats[period].calories;
          bValue = b.stats[period].calories;
          break;
        case 'elevation':
          aValue = a.stats[period].elevationGain;
          bValue = b.stats[period].elevationGain;
          break;
        default:
          aValue = `${a.firstname} ${a.lastname}`.toLowerCase();
          bValue = `${b.firstname} ${b.lastname}`.toLowerCase();
      }
      
      if (sortOrder === 'desc') {
        return aValue < bValue ? 1 : aValue > bValue ? -1 : 0;
      } else {
        return aValue > bValue ? 1 : aValue < bValue ? -1 : 0;
      }
    });
    
    return membersStats;
  } catch (err) {
    console.error('Error in fetchMembersData:', err);
    return [];
  }
}

// Appeler la fonction principale
membersStats = await fetchMembersData();
---

<Layout title="Statistiques des membres - Strava Club Tracker">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center">
            <a href="/" class="text-2xl font-bold text-gray-900 hover:text-orange-600">
              Strava Club Tracker
            </a>
            <span class="ml-4 px-3 py-1 text-sm font-medium text-orange-600 bg-orange-100 rounded-full">
              Club Blanko
            </span>
          </div>
          <div class="flex items-center space-x-4">
            <a href="/" class="text-sm text-gray-600 hover:text-gray-900">
              Retour à l'accueil
            </a>
            <form action="/logout" method="post">
              <button 
                type="submit"
                class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500"
              >
                Déconnexion
              </button>
            </form>
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-8">
        <div class="flex justify-between items-center mb-6">
          <h1 class="text-3xl font-bold text-gray-900">Statistiques des membres</h1>
          
          <div class="flex items-center space-x-4">
            <label class="text-sm font-medium text-gray-700">Période:</label>
            <select 
              id="period-select"
              class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-orange-500"
              onchange="window.location.href = `/members?period=${this.value}`"
            >
              <option value="weekly" selected={period === 'weekly'}>Cette semaine</option>
              <option value="monthly" selected={period === 'monthly'}>Ce mois</option>
              <option value="yearly" selected={period === 'yearly'}>Cette année</option>
              <option value="allTime" selected={period === 'allTime'}>Depuis toujours</option>
            </select>
          </div>
        </div>

        {error ? (
          <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-6">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">Erreur</h3>
                <div class="mt-2 text-sm text-red-700">
                  <p>{error}</p>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <div class="bg-white shadow-sm rounded-lg overflow-hidden">
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      <a href={getSortUrl('name')} class="hover:text-orange-600 flex items-center">
                        Membre
                        <span class="ml-1">{getSortIcon('name')}</span>
                      </a>
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      <a href={getSortUrl('distance')} class="hover:text-orange-600 flex items-center">
                        Distance
                        <span class="ml-1">{getSortIcon('distance')}</span>
                      </a>
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      <a href={getSortUrl('time')} class="hover:text-orange-600 flex items-center">
                        Temps d'activité
                        <span class="ml-1">{getSortIcon('time')}</span>
                      </a>
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      <a href={getSortUrl('calories')} class="hover:text-orange-600 flex items-center">
                        Calories
                        <span class="ml-1">{getSortIcon('calories')}</span>
                      </a>
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      <a href={getSortUrl('elevation')} class="hover:text-orange-600 flex items-center">
                        Dénivelé positif
                        <span class="ml-1">{getSortIcon('elevation')}</span>
                      </a>
                    </th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  {membersStats.map((member) => {
                    const stats = member.stats[period];
                    return (
                      <tr key={member.id} class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap">
                          <div class="flex items-center">
                            <div class="flex-shrink-0 h-10 w-10">
                              <img 
                                class="h-10 w-10 rounded-full" 
                                src={member.profile} 
                                alt={`${member.firstname} ${member.lastname}`}
                              />
                            </div>
                            <div class="ml-4">
                              <div class="text-sm font-medium text-gray-900">
                                {member.firstname} {member.lastname}
                              </div>
                              <div class="text-sm text-gray-500">
                                @{member.username}
                              </div>
                            </div>
                          </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                          {formatDistance(stats.distance)}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                          {formatTime(stats.movingTime)}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                          {stats.calories.toLocaleString()} kcal
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                          {formatElevation(stats.elevationGain)}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </div>
    </main>
  </div>
</Layout>
